generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
  output        = "./generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(cuid())
  title_en    String
  title_am    String
  slug        String        @unique
  summary_en  String
  summary_am  String
  status      ProjectStatus @default(ACTIVE)
  body_en     String?
  body_am     String?
  coverImage  String?
  isPublished Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ContactMessageStatus {
  UNREAD
  READ
}

model Newsletter {
  id           String   @id @default(cuid())
  title_en     String
  title_am     String
  body_en      String?
  body_am      String?
  email        String   @unique
  locale       String   @default("en")
  subscribed   Boolean  @default(true)
  source       String?
  isPublished  Boolean  @default(false)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  subscribedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BoardMember {
  id        String   @id @default(cuid())
  fullName  String
  role      String
  bio       String?
  imageUrl  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GovernanceMember {
  id            String   @id @default(cuid())
  name_en       String
  name_am       String
  role_en       String
  role_am       String
  bio_en        String?
  bio_am        String?
  imagePath     String?
  order         Int      @default(0)
  isBoardMember Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([order])
  @@index([isBoardMember])
}

model Donation {
  id              String        @id @default(cuid())
  donorName       String?
  donorEmail      String?
  donorPhone      String?
  tx_ref          String        @unique
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("ETB")
  paymentProvider String        @default("chapa")
  paymentStatus   PaymentStatus @default(PENDING)
  chapaCheckoutId String?
  paidAt          DateTime?
  metadata        Json?
  centerId        String?
  schoolCenter    SchoolCenter? @relation(fields: [centerId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tx_ref])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([centerId])
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactMessageStatus @default(UNREAD)
  createdAt DateTime             @default(now())

  @@index([status])
  @@index([createdAt])
}

enum StaffRole {
  TEACHER
  ADMIN
  SUPPORT
}

enum ItemCategory {
  STATIONERY
  UNIFORM
  TEXTBOOK
  ASSET
}

enum ExpenseCategory {
  FOOD
  UTILITIES
  MAINTENANCE
  CONSTRUCTION
}

enum UserRole {
  ADMIN
  STAFF
}

model SchoolCenter {
  id        String   @id @default(cuid())
  name      String
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff     Staff[]
  inventory InventoryItem[]
  expenses  SchoolExpense[]
  donations Donation[]
  students  Student[]
}

model Staff {
  id            String    @id @default(cuid())
  name          String
  role          StaffRole
  baseSalary    Decimal   @db.Decimal(12, 2)
  pensionNumber String?
  photoUrl      String?
  isActive      Boolean   @default(true)
  centerId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  center         SchoolCenter    @relation(fields: [centerId], references: [id], onDelete: Restrict)
  payrollRecords PayrollRecord[]
  account        StaffAccount?

  @@index([centerId])
}

model PayrollRecord {
  id                  String   @id @default(cuid())
  staffId             String
  month               Int
  year                Int
  grossSalary         Decimal  @db.Decimal(12, 2)
  netSalary           Decimal  @db.Decimal(12, 2)
  incomeTax           Decimal  @db.Decimal(12, 2)
  pensionContribution Decimal  @db.Decimal(12, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Restrict)

  @@index([staffId])
}

model InventoryItem {
  id        String       @id @default(cuid())
  name      String
  category  ItemCategory
  quantity  Int          @default(0)
  minStock  Int          @default(0)
  centerId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  center SchoolCenter @relation(fields: [centerId], references: [id], onDelete: Restrict)

  @@index([centerId])
}

model SchoolExpense {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory
  description String?
  centerId    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  center SchoolCenter @relation(fields: [centerId], references: [id], onDelete: Restrict)

  @@index([centerId])
}

model Student {
  id              String   @id @default(cuid())
  name            String
  gradeLevel      String
  guardianContact String?
  isActive        Boolean  @default(true)
  centerId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  center SchoolCenter @relation(fields: [centerId], references: [id], onDelete: Restrict)

  @@index([centerId])
}

model StaffAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      UserRole @default(STAFF)
  staffId   String   @unique
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
