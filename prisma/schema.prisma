generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
  output        = "./generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  title_en    String
  title_am    String
  slug        String   @unique
  summary_en  String
  summary_am  String
  status      ProjectStatus @default(ACTIVE)
  body_en     String?
  body_am     String?
  coverImage  String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ContactMessageStatus {
  UNREAD
  READ
}

model Newsletter {
  id          String   @id @default(cuid())
  title_en    String
  title_am    String
  body_en     String?
  body_am     String?
  email       String   @unique
  locale      String   @default("en")
  subscribed  Boolean  @default(true)
  source      String?
  isPublished Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  subscribedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BoardMember {
  id         String   @id @default(cuid())
  fullName   String
  role       String
  bio        String?
  imageUrl   String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model GovernanceMember {
  id            String   @id @default(cuid())
  name_en       String
  name_am       String
  role_en       String
  role_am       String
  bio_en        String?
  bio_am        String?
  imagePath     String?
  order         Int      @default(0)
  isBoardMember Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([order])
  @@index([isBoardMember])
}

model Donation {
  id              String   @id @default(cuid())
  donorName       String?
  donorEmail      String?
  donorPhone      String?
  tx_ref          String   @unique
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("ETB")
  paymentProvider String   @default("chapa")
  paymentStatus   PaymentStatus @default(PENDING)
  chapaCheckoutId String?
  paidAt          DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tx_ref])
  @@index([paymentStatus])
  @@index([createdAt])
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactMessageStatus @default(UNREAD)
  createdAt DateTime             @default(now())

  @@index([status])
  @@index([createdAt])
}
